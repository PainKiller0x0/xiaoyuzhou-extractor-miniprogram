/* pages/index/index.wxss */
@import "/app.wxss"; 

.container {
  padding: 60rpx 40rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-sizing: border-box;
  background: linear-gradient(to bottom, var(--bg-color), var(--hover-bg-color)); 
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "Noto Sans", sans-serif;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
}
.logo {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 30rpx;
  border-radius: 36rpx;
  box-shadow: 0 8rpx 24rpx var(--shadow-color); 
  border: 4rpx solid rgba(255, 255, 255, 0.6);
}
.title-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.main-title {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--title-color);
  margin-bottom: 10rpx;
  text-shadow: 1rpx 1rpx 2rpx rgba(0,0,0,0.05);
}
.sub-title {
  font-size: 36rpx;
  font-weight: 500;
  color: var(--secondary-text-color);
  margin-bottom: 20rpx;
}
.description-text {
  font-size: 28rpx;
  color: var(--secondary-text-color); 
  text-align: center;
  line-height: 1.4;
  padding: 0 20rpx;
}

.content-area {
  width: 100%;
  flex-grow: 1;
  display: flex;
  flex-direction: column;
  justify-content: flex-start; 
  align-items: center;
  margin-bottom: 40rpx;
  box-sizing: border-box;
}

.content-card-base {
  width: 100%;
  background-color: var(--url-bg-color);
  border-radius: 20rpx;
  box-shadow: 0 8rpx 20rpx var(--shadow-color); 
  border: 1rpx solid var(--border-color);
  box-sizing: border-box;
  animation: fadeIn 0.5s ease-out forwards; 
  position: relative;
  margin-bottom: 30rpx; 
}

.input-section-card {
  padding: 30rpx;
  min-height: 240rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  align-items: flex-start;
  padding-bottom: 70rpx; 
}
.url-input {
  width: 100%;
  height: auto;
  font-size: 32rpx;
  line-height: 1.6;
  color: var(--text-color); 
  box-sizing: border-box;
  flex-grow: 1;
}
.input-placeholder {
  color: var(--secondary-text-color);
}

.paste-link-button {
  position: absolute;
  right: 25rpx;
  bottom: 25rpx;
  background-color: rgba(0, 0, 0, 0.08);
  color: var(--secondary-text-color); 
  font-size: 26rpx;
  padding: 16rpx 32rpx;
  border-radius: 12rpx;
  line-height: 1;
  height: auto;
  width: auto !important;
  min-width: 0 !important;
  border: none;
  box-shadow: none;
  box-sizing: border-box;
  text-align: center; 
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.3s ease-out, transform 0.3s ease-out;
  opacity: 0;
  transform: translateY(10rpx); 
  pointer-events: none;
}
.paste-link-button.paste-link-button--visible {
  opacity: 1;
  transform: translateY(0);
  pointer-events: auto; 
}
.paste-link-button.paste-link-button--hidden {
  opacity: 0;
  transform: translateY(10rpx);
  pointer-events: none; 
}
.paste-link-button::before { content: "粘贴链接"; }
.paste-link-button::after { border: none; }
.paste-link-button:active {
  background-color: rgba(0, 0, 0, 0.15);
  transform: scale(0.96);
}

.result-section-card {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  min-height: auto; 
}
.podcast-cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx var(--shadow-color);
  margin-bottom: 25rpx;
}
.podcast-info {
  margin-bottom: 25rpx;
}
.podcast-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--secondary-text-color) !important;
  display: block;
  margin-bottom: 10rpx;
}
.podcast-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--title-color) !important;
  word-break: break-all;
  line-height: 1.5;
  padding: 0 10rpx;
}
.result-url-wrapper {
  margin-top: 25rpx;
  width: 100%;
}
.result-url {
  font-size: 30rpx;
  color: var(--copy-btn-hover-bg);
  word-break: break-all;
  line-height: 1.6;
  text-align: center;
  padding: 15rpx 0;
  width: 100%;
  display: block;
  background-color: var(--hover-bg-color);
  border-radius: 12rpx;
}
.clickable-url:active {
  background-color: var(--hover-bg-color);
  border-radius: 8rpx;
}
.copy-hint-text {
  font-size: 26rpx;
  color: var(--secondary-text-color);
  margin-top: 10rpx;
  text-align: center;
  width: 100%;
  display: block;
}

.highlights-card {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  text-align: left;
}
.highlights-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.highlights-icon {
  font-size: 36rpx;
  margin-right: 15rpx;
}
.highlights-title {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--title-color);
}
.highlight-quote {
  font-size: 32rpx;
  font-style: italic;
  font-weight: 500;
  color: var(--text-color);
  line-height: 1.6;
  margin-bottom: 25rpx;
  padding: 0 10rpx;
  border-left: 5rpx solid var(--copy-btn-bg);
  padding-left: 20rpx;
}
.highlight-summary {
  font-size: 30rpx;
  color: var(--text-color);
  line-height: 1.6;
  margin-bottom: 25rpx;
}
.summary-label {
  font-weight: 500;
  color: var(--title-color);
  margin-bottom: 5rpx;
  display: block;
}
.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}
.tag {
  background-color: var(--hover-bg-color);
  color: var(--secondary-text-color);
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

.shownote-card {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  text-align: left;
}
.shownote-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}
.shownote-icon {
  font-size: 36rpx;
  margin-right: 15rpx;
  color: var(--title-color);
}
.shownote-title {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--title-color);
}
.shownote-content {
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-color);
  white-space: pre-wrap;
  word-break: break-all;
}

.bottom-actions-fixed {
  width: 100%;
  padding: 20rpx 40rpx;
  box-sizing: border-box;
  position: fixed;
  bottom: 0;
  left: 0;
  z-index: 100;
  background: linear-gradient(to top, var(--bg-color) 70%, rgba(240, 242, 245, 0));
  display: flex;
  flex-direction: column;
  align-items: center;
}

.primary-actions-row {
  width: 100%;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx; 
}
.history-icon-button {
  flex: 0 0 180rpx; 
  height: 108rpx;
  border-radius: 54rpx; 
  background-color: var(--url-bg-color);
  border: 2rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx var(--shadow-color);
  transition: all 0.2s ease-in-out;
  padding: 0;
  color: var(--title-color);
  font-size: 30rpx;
  font-weight: 600;
}
.history-icon-button:active {
  transform: translateY(2rpx) scale(0.96);
  background-color: var(--hover-bg-color);
  box-shadow: 0 4rpx 10rpx var(--shadow-color);
}

.action-button {
  flex: 1; 
  height: 108rpx;
  color: var(--btn-text-color); 
  font-size: 36rpx;
  font-weight: 600;
  border-radius: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx var(--shadow-color); 
  transition: all 0.2s ease-in-out;
  letter-spacing: 1rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.action-button[disabled] {
  background: linear-gradient(to right, var(--btn-disabled-bg), var(--btn-disabled-bg)) !important; 
  opacity: 0.8;
}
.extract-button {
  background: linear-gradient(to right, var(--download-btn-bg), var(--download-btn-hover-bg)); 
}
.extract-button:active {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 0 4rpx 10rpx var(--shadow-color); 
}
.copy-button {
  background: linear-gradient(to right, var(--copy-btn-bg), var(--copy-btn-hover-bg));
}
.copy-button:active {
  transform: translateY(2rpx) scale(0.98);
  box-shadow: 0 4rpx 10rpx var(--shadow-color);
}

.secondary-action-area {
  margin-top: 30rpx;
  width: 100%;
  text-align: center;
}
.secondary-button {
  background-color: transparent;
  color: var(--secondary-text-color); 
  font-size: 30rpx;
  font-weight: 500;
  padding: 10rpx 25rpx;
  border: 1rpx solid var(--border-color);
  border-radius: 40rpx;
  line-height: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease-in-out;
}
.secondary-button::after { border: none; }
.secondary-button:active {
  background-color: var(--hover-bg-color); 
  transform: scale(0.98);
}

.status-message-box {
  padding: 20rpx 30rpx;
  background-color: var(--hover-bg-color); 
  border: 1rpx solid var(--status-error-color);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column; 
  align-items: center;
  width: 100%;
  box-sizing: border-box;
  animation: fadeIn 0.4s ease-out forwards;
}
.status-message-icon {
  font-size: 36rpx;
  margin-right: 0;
  margin-bottom: 10rpx; 
  color: var(--status-error-color); 
}
.status-message-text {
  font-size: 28rpx;
  color: var(--text-color); 
  line-height: 1.4;
  text-align: center; 
  margin-bottom: 20rpx;
}
.status-error-text {
  color: var(--status-error-color); 
  font-weight: 500;
}

.retry-button,
.feedback-button,
.reset-from-error-button { 
  width: 80%;
  height: 80rpx;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease-in-out;
  margin-top: 15rpx; 
  box-sizing: border-box;
  border: 1rpx solid;
}
.retry-button {
  background-color: var(--copy-btn-bg); 
  color: var(--btn-text-color);
  border-color: var(--copy-btn-bg); 
}
.retry-button:active {
  background-color: var(--copy-btn-hover-bg);
  transform: scale(0.98);
}
.feedback-button,
.reset-from-error-button { 
  background-color: transparent;
  color: var(--secondary-text-color); 
  border-color: var(--secondary-text-color); 
}
.feedback-button:active,
.reset-from-error-button:active {
  background-color: var(--hover-bg-color);
  transform: scale(0.98);
}

.history-popup-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  flex-direction: column;
  justify-content: flex-end; 
  animation: fadeInOverlay 0.2s ease-out forwards;
}
.history-popup-content {
  background-color: var(--bg-color);
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  padding: 40rpx 30rpx max(env(safe-area-inset-bottom), 40rpx);
  max-height: 75vh;
  display: flex;
  flex-direction: column;
  animation: slideUpPopup 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  box-shadow: 0 -10rpx 40rpx rgba(0, 0, 0, 0.08);
}
.history-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border-color);
}
.history-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--title-color);
}
.history-header-actions {
  display: flex;
  align-items: center;
  gap: 30rpx;
}
.clear-history {
  font-size: 26rpx;
  color: var(--status-error-color);
  background-color: rgba(231, 76, 60, 0.08);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  transition: all 0.2s;
}
.clear-history:active {
  transform: scale(0.95);
  background-color: rgba(231, 76, 60, 0.15);
}
.close-history {
  font-size: 40rpx;
  line-height: 1;
  color: var(--secondary-text-color);
  padding: 5rpx 10rpx;
}
.close-history:active {
  opacity: 0.6;
}
.history-list-scroll {
  max-height: 55vh; 
}
.history-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx; 
}
.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background-color: var(--url-bg-color);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx var(--shadow-color);
  transition: all 0.2s;
}
.history-item:active {
  transform: scale(0.98);
  background-color: var(--hover-bg-color);
}
.history-item-content {
  display: flex;
  flex-direction: column;
  flex: 1;
  overflow: hidden;
  margin-right: 20rpx;
}
.history-item-title {
  font-size: 28rpx;
  color: var(--text-color);
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis; 
  margin-bottom: 10rpx;
}
.history-item-time {
  font-size: 22rpx;
  color: var(--secondary-text-color);
}
.history-item-icon {
  font-size: 36rpx;
  opacity: 0.8;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(15rpx); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeInOverlay {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes slideUpPopup {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* 💡 独立出来的生成海报按钮样式 */
.generate-poster-btn {
  margin-bottom: 30rpx; /* 与下方的卡片保持间距 */
  width: 100%;
  height: 90rpx;
  background-color: var(--title-color); 
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 500;
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx var(--shadow-color);
  transition: all 0.2s;
}
.generate-poster-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
  background-color: #1a252f;
}